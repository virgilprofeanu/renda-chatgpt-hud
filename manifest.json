{
  "manifest_version": 3,
  "name": "RENDA VIGILIA HUD pentru ChatGPT",
  "version": "4.12.1",
  "description": "Carcasă vizuală RENDA/VIGILIA peste ChatGPT + monitor CPU/RAM din HUD-ul local. Nu citește și nu transmite conversațiile.",
  "author": "Virgil Profeanu",
  "minimum_chrome_version": "120",
  "icons": {
    "128": "icon128.png"
  },
  "permissions": ["userScripts", "alarms", "storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
